{
  "builds": [
    {
      "src": "api/data.js",
      "use": "@vercel/node"
    },
    {
      "src": "build/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "build/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/data.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "/build/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/build/index.html"
    }
  ]
}
